{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./src"
  },
  "include": ["src/main.tsx", "src/App.tsx", "src/vite-env.d.ts", "src/app/**/*.ts", "src/app/**/*.tsx"],
  "exclude": ["src/api/**", "src/components/**", "src/context/**", "src/hooks/**", "src/pages/**", "src/types/**"]
}
